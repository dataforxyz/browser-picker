#!/usr/bin/env python3
# browser-picker-recommend — local, offline habit recommender for browser-picker.
#
# Learns which browser/profile (and whether you used a private window) you pick for which
# links, and once you've opened a similar place the same way a couple of times, lets the
# picker offer a one-click "make default" entry at the top of its menu. It generalizes across
# URLs (same repo -> the repo; many repos in an org -> the org; many orgs on a host you only
# use with one profile -> the host), staying "pure" so a suggested rule never captures links
# you open with a *different* profile (or a different private/normal choice). No network, no
# API keys: your URLs never leave the machine. GUI-free and importable, so the pure logic is
# unit-tested without GTK.
#
# CLI (called by bin/browser-picker):
#   browser-picker-recommend record --url URL --label LABEL [--private 1]
#   browser-picker-recommend peek   --url URL          -> prints "pattern\tlabel\tprivate"
#   browser-picker-recommend addrule --pattern P --label L [--private 1]
#       Append "1|||P|||L[|||1]" to rules.conf (idempotent; before any catch-all).
#
# Store: ~/.config/browser-picker/history.json   Settings: ~/.config/browser-picker/settings.conf
import json
import os
import sys
import time
import urllib.parse

CONF = os.path.join(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")), "browser-picker"
)
STORE = os.path.join(CONF, "history.json")
SETTINGS = os.path.join(CONF, "settings.conf")
RULES_FILE = os.path.join(CONF, "rules.conf")
MAX_EVENTS = 1000
SEG_CAP = 2  # generalize at most to host + 2 path segments (matches rules editor default_pattern)


def threshold():
    """Total picks of the same place+profile before the picker offers a default.

    Default 2 — the offer appears on the *1st repeat* (the 2nd open). settings.conf
    `threshold=N` wins, then $BROWSER_PICKER_SUGGEST_THRESHOLD. The file lets you tune it even
    though the .desktop launcher passes no environment.
    """
    try:
        with open(SETTINGS) as f:
            for line in f:
                line = line.strip()
                if line.startswith("threshold="):
                    return max(2, int(line.split("=", 1)[1]))
    except (OSError, ValueError):
        pass
    try:
        return max(2, int(os.environ.get("BROWSER_PICKER_SUGGEST_THRESHOLD", "2")))
    except ValueError:
        return 2


def url_parts(url):
    """(host, segs) for an http(s) URL; (None, []) for anything else (mailto, etc.)."""
    if not isinstance(url, str):
        return None, []
    low = url.lower()
    if not (low.startswith("http://") or low.startswith("https://")):
        return None, []
    p = urllib.parse.urlsplit(url)
    host = p.netloc.split("@")[-1]  # keep any :port so the pattern matches the real URL
    if host.startswith("www."):
        host = host[4:]
    if not host:
        return None, []
    segs = [s for s in p.path.split("/") if s]
    return host, segs


def common_prefix(seg_lists):
    """Longest shared leading segments across a list of segment-lists."""
    if not seg_lists:
        return []
    out = []
    for i in range(min(len(s) for s in seg_lists)):
        col = seg_lists[0][i]
        if all(s[i] == col for s in seg_lists):
            out.append(col)
        else:
            break
    return out


def make_pattern(host, segs):
    return "/".join([host] + list(segs[:SEG_CAP]))


def _ident(ev):
    return (ev.get("label"), bool(ev.get("private")))


def _under(host, pat_segs, ev):
    """Is event ev under host + pat_segs prefix? (structural boundary match)"""
    if ev.get("host") != host:
        return False
    esegs = ev.get("segs") or []
    if len(esegs) < len(pat_segs):
        return False
    return all(esegs[i] == pat_segs[i] for i in range(len(pat_segs)))


def recommend(events, label, host, need, private=False):
    """Best (pattern, count) for (label, private, host) given >= need picks, or None.

    Generalizes to the deepest common ancestor of what was actually opened, then requires that
    this profile/private choice *dominates* under the pattern — it owns at least `need` picks
    and a strict majority of them — so one stray pick with another profile can't veto an
    obvious habit, but a genuine tie (50/50) still stays quiet rather than guess wrong.
    """
    if not host:
        return None
    ident = (label, bool(private))
    cluster = [e for e in events if e.get("host") == host and _ident(e) == ident]
    if len(cluster) < need:
        return None
    others = [e for e in events if e.get("host") == host and _ident(e) != ident]

    def dominant(pat_segs):
        mine = sum(1 for e in cluster if _under(host, pat_segs, e))
        opp = sum(1 for e in others if _under(host, pat_segs, e))
        return mine if (mine >= need and mine > opp) else 0

    pref = common_prefix([e.get("segs") or [] for e in cluster])[:SEG_CAP]
    m = dominant(pref)
    if m:
        return make_pattern(host, pref), m
    narrow = (cluster[-1].get("segs") or [])[:SEG_CAP]
    if narrow:
        m = dominant(narrow)
        if m:
            return make_pattern(host, narrow), m
    return None


def peek(events, host, segs, threshold_n):
    """For a link about to open, suggest (pattern, label, private) from prior habits, else None.

    Needs threshold_n-1 prior picks (so the offer appears on the threshold_n-th open) and the
    suggested pattern must actually cover the link being opened.
    """
    if not host:
        return None
    need = max(1, threshold_n - 1)
    idents, best = [], None
    for e in events:
        if e.get("host") == host and _ident(e) not in idents:
            idents.append(_ident(e))
    for label, private in idents:
        rec = recommend(events, label, host, need, private)
        if not rec:
            continue
        pattern, count = rec
        if not _under(host, pattern.split("/")[1:], {"host": host, "segs": segs}):
            continue
        if best is None or count > best[3]:
            best = (pattern, label, private, count)
    return (best[0], best[1], best[2]) if best else None


def record_event(store, url, label, ts, private=False):
    """Append one pick. Returns the host, or None for non-http(s) links."""
    host, segs = url_parts(url)
    if host is None:
        return None
    events = store.setdefault("events", [])
    ev = {"url": url, "host": host, "segs": segs, "label": label, "ts": ts}
    if private:
        ev["private"] = True
    events.append(ev)
    if len(events) > MAX_EVENTS:
        del events[:-MAX_EVENTS]
    return host


def add_rule(pattern, label, private=False):
    """Append an enabled rule to rules.conf if absent; keep it before any catch-all '*'."""
    os.makedirs(CONF, exist_ok=True)
    new = "1|||%s|||%s|||1" % (pattern, label) if private else "1|||%s|||%s" % (pattern, label)
    lines = []
    if os.path.exists(RULES_FILE):
        with open(RULES_FILE) as f:
            lines = [ln.rstrip("\n") for ln in f]
    for ln in lines:
        parts = ln.split("|||")
        if len(parts) >= 3 and parts[1] == pattern and parts[2] == label \
                and (len(parts) > 3 and parts[3] == "1") == bool(private):
            return False  # already there
    insert_at = len(lines)
    for i, ln in enumerate(lines):
        parts = ln.split("|||")
        if len(parts) >= 3 and parts[1] == "*":
            insert_at = i
            break
    lines.insert(insert_at, new)
    with open(RULES_FILE, "w") as f:
        f.write("\n".join(lines) + "\n")
    return True


def load_store():
    try:
        with open(STORE) as f:
            d = json.load(f)
        if isinstance(d, dict):
            d.setdefault("events", [])
            return d
    except (OSError, ValueError):
        pass
    return {"events": []}


def save_store(store):
    os.makedirs(CONF, exist_ok=True)
    tmp = STORE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(store, f)
    os.replace(tmp, STORE)


def _opt(argv, name):
    if name in argv:
        i = argv.index(name)
        if i + 1 < len(argv):
            return argv[i + 1]
    return None


def main(argv):
    if not argv:
        return 0
    cmd = argv[0]
    if cmd == "record":
        url, label = _opt(argv, "--url"), _opt(argv, "--label")
        if not url or not label:
            return 2
        store = load_store()
        record_event(store, url, label, int(time.time()), _opt(argv, "--private") == "1")
        save_store(store)
        return 0
    if cmd == "peek":
        url = _opt(argv, "--url")
        if not url:
            return 2
        host, segs = url_parts(url)
        rec = peek(load_store().get("events", []), host, segs, threshold())
        if rec:
            sys.stdout.write("%s\t%s\t%s\n" % (rec[0], rec[1], "1" if rec[2] else "0"))
        return 0
    if cmd == "addrule":
        pattern, label = _opt(argv, "--pattern"), _opt(argv, "--label")
        if not pattern or not label:
            return 2
        add_rule(pattern, label, _opt(argv, "--private") == "1")
        return 0
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
