#!/usr/bin/env python3
# browser-picker-rules — GUI to manage smart-default rules for browser-picker.
# Each rule: [enabled checkbox] [editable pattern] [browser/profile dropdown] [⚠] [▲ ▼ ✕].
# Plus a "Unmatched links →" default (writes a catch-all "*" rule).
#
# Optional arg: a URL. When given, a new editable row is pre-filled with a sensible
# pattern derived from that URL, and the link is opened (via browser-picker) after Save.
import gi, os, sys, json, shutil, subprocess, configparser, urllib.parse
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, GLib

CONF = os.path.join(GLib.get_user_config_dir(), "browser-picker")
BROWSERS = os.path.join(CONF, "browsers.conf")
RULES = os.path.join(CONF, "rules.conf")
HOME = os.path.expanduser("~")
ASK = "Always ask (show the menu)"
NONE_FOUND = "(no browsers found)"


def read_lines(path):
    if not os.path.exists(path):
        return []
    out = []
    with open(path) as f:
        for line in f:
            s = line.strip()
            if not s or s.startswith("#") or "|||" not in s:
                continue
            out.append(s)
    return out


def load_labels():
    return [ln.split("|||", 1)[0] for ln in read_lines(BROWSERS)]


def load_rules():
    rules = []
    for ln in read_lines(RULES):
        parts = ln.split("|||")
        if len(parts) == 3:
            en, pat, lbl = parts
            rules.append((en == "1", pat, lbl))
    return rules


def parse_args(argv):
    """(url, pattern, label, no_open) from argv (the args after the program name).

    Positional URL stays backward-compatible; --pattern/--label pre-fill the new row (used by
    the recommender's suggestion), and --no-open skips relaunching the link on Save (the
    browser is already open from the pick that triggered the suggestion).
    """
    url = pattern = label = None
    no_open = False
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--no-open":
            no_open = True
        elif a == "--pattern" and i + 1 < len(argv):
            i += 1
            pattern = argv[i]
        elif a == "--label" and i + 1 < len(argv):
            i += 1
            label = argv[i]
        elif not a.startswith("--") and url is None:
            url = a
        i += 1
    return url, pattern, label, no_open


def default_pattern(url):
    p = urllib.parse.urlsplit(url if "://" in url else "http://" + url)
    host = p.netloc.split("@")[-1]
    if host.startswith("www."):
        host = host[4:]
    segs = [s for s in p.path.split("/") if s]
    return "/".join([host] + segs[:2])


def normcmd(c):
    return " ".join(c.replace('"', "").split())


def model_items(labels, label):
    """Dropdown choices for a rule, preserving an unknown label so it isn't lost."""
    items = list(labels)
    missing = bool(label) and label not in items
    if missing:
        items = [label] + items
    return (items or [NONE_FOUND]), missing


def discover_browsers():
    """Return [(label, command)] for installed browsers + their profiles."""
    found = []
    for disp, binname, base in (
        ("Chromium", "chromium", f"{HOME}/.config/chromium"),
        ("Brave", "brave", f"{HOME}/.config/BraveSoftware/Brave-Browser"),
        ("Chrome", "google-chrome-stable", f"{HOME}/.config/google-chrome"),
        ("Edge", "microsoft-edge-stable", f"{HOME}/.config/microsoft-edge"),
    ):
        if not shutil.which(binname):
            continue
        ls = os.path.join(base, "Local State")
        cache = {}
        if os.path.exists(ls):
            try:
                with open(ls) as f:
                    cache = json.load(f).get("profile", {}).get("info_cache", {})
            except Exception:
                cache = {}
        if cache:
            for dirname, info in cache.items():
                name = info.get("name") or dirname
                found.append((f"{disp} — {name}", f'{binname} --profile-directory="{dirname}"'))
        else:
            found.append((disp, binname))
    for disp, binname, ini in (
        ("Firefox", "firefox", f"{HOME}/.mozilla/firefox/profiles.ini"),
        ("Zen", "zen-browser", f"{HOME}/.config/zen/profiles.ini"),
    ):
        if not shutil.which(binname):
            continue
        names = []
        if os.path.exists(ini):
            cp = configparser.ConfigParser()
            try:
                cp.read(ini)
                for sec in cp.sections():
                    if cp.has_option(sec, "Name"):
                        names.append(cp.get(sec, "Name"))
            except Exception:
                names = []
        if names:
            for n in names:
                found.append((f"{disp} — {n}", f'{binname} -P "{n}"'))
        else:
            found.append((disp, binname))
    return found


class RulesApp(Gtk.Application):
    def __init__(self, url=None, pattern=None, label=None, no_open=False):
        super().__init__(application_id="dev.local.BrowserPickerRules")
        self.url = url
        self.pattern = pattern
        self.label = label
        self.no_open = no_open

    def model_items(self, label):
        return model_items(self.labels, label)

    def do_activate(self):
        self.labels = load_labels()
        self.rows = []

        win = Gtk.ApplicationWindow(application=self, title="Browser Picker — Rules")
        win.set_default_size(780, 500)
        self.win = win

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        for m in ("top", "bottom", "start", "end"):
            getattr(root, f"set_margin_{m}")(12)
        win.set_child(root)

        help_lbl = Gtk.Label(xalign=0)
        help_lbl.set_markup(
            "Links matching an <b>enabled</b> rule open directly in the chosen profile "
            "(no menu).\nPattern: plain text matches on path boundaries (covers a URL and "
            "its child paths); <b>*</b>/<b>?</b> = glob; <b>regex:</b> prefix = regex. "
            "First match wins — use ▲ ▼ to set priority."
        )
        help_lbl.set_wrap(True)
        root.append(help_lbl)

        if self.url:
            ctx = Gtk.Label(xalign=0)
            if self.label:
                ctx.set_markup(
                    f"You've opened <tt>{GLib.markup_escape_text(self.url)}</tt> in "
                    f"<b>{GLib.markup_escape_text(self.label)}</b> a few times.\n"
                    "Review the pattern below — trim it to the scope you want — then Save.")
            else:
                ctx.set_markup(f"Creating a rule for: <tt>{GLib.markup_escape_text(self.url)}</tt>  "
                               "— trim the pattern to the scope you want, then Save.")
            ctx.set_wrap(True)
            root.append(ctx)

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for text, w in (("On", 30), ("Pattern", 300), ("Open in", 200), ("", 110)):
            l = Gtk.Label(label=text, xalign=0)
            l.set_size_request(w, -1)
            header.append(l)
        root.append(header)

        scroller = Gtk.ScrolledWindow(vexpand=True)
        self.list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        scroller.set_child(self.list_box)
        root.append(scroller)

        # Default for unmatched links (a trailing catch-all "*" rule).
        rules = load_rules()
        default_label = None
        if rules and rules[-1][0] and rules[-1][1] == "*":
            default_label = rules[-1][2]
            rules = rules[:-1]

        defbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        defbox.append(Gtk.Label(label="Unmatched links →", xalign=0))
        ditems, dmissing = self.model_items(default_label)
        self.default_items = [ASK] + ditems
        self.default_drop = Gtk.DropDown.new_from_strings(self.default_items)
        if default_label and default_label in ditems:
            self.default_drop.set_selected(1 + ditems.index(default_label))
        else:
            self.default_drop.set_selected(0)
        self.default_warn = Gtk.Label(label="⚠")
        self.default_warn.set_visible(dmissing)
        if dmissing:
            self.default_warn.set_tooltip_text(f"Profile '{default_label}' not found.")
        defbox.append(self.default_drop)
        defbox.append(self.default_warn)
        root.append(defbox)

        btns = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        add_btn = Gtk.Button(label="＋ Add rule")
        add_btn.connect("clicked", lambda _b: self.add_row(True, "", None))
        rescan_btn = Gtk.Button(label="⟳ Rescan profiles")
        rescan_btn.set_tooltip_text("Re-detect installed browsers and profiles")
        rescan_btn.connect("clicked", self.on_rescan)
        save_btn = Gtk.Button(label="Save")
        save_btn.add_css_class("suggested-action")
        save_btn.connect("clicked", self.on_save)
        self.status = Gtk.Label(xalign=0)
        btns.append(add_btn)
        btns.append(rescan_btn)
        btns.append(self.status)
        btns.append(Gtk.Box(hexpand=True))
        btns.append(save_btn)
        root.append(btns)

        prefill_entry = None
        if self.url:
            self.add_row(True, self.pattern or default_pattern(self.url), self.label)
            prefill_entry = self.rows[-1]["entry"]
        for en, pat, lbl in rules:
            self.add_row(en, pat, lbl)
        if not self.rows:
            self.add_row(True, "", None)

        win.present()
        if prefill_entry is not None:
            def focus():
                prefill_entry.grab_focus()
                prefill_entry.select_region(0, -1)
                return False
            GLib.idle_add(focus)

    def add_row(self, enabled, pattern, label):
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        check = Gtk.CheckButton()
        check.set_active(bool(enabled))
        check.set_size_request(30, -1)

        entry = Gtk.Entry()
        entry.set_text(pattern or "")
        entry.set_placeholder_text("e.g. github.com/myorg/myrepo  (or regex:… )")
        entry.set_hexpand(True)
        entry.set_size_request(300, -1)

        items, missing = self.model_items(label)
        drop = Gtk.DropDown.new_from_strings(items)
        if label in items:
            drop.set_selected(items.index(label))
        drop.set_size_request(200, -1)

        warn = Gtk.Label(label="⚠")
        warn.set_size_request(18, -1)
        warn.set_visible(missing)
        if missing:
            warn.set_tooltip_text(f"Profile '{label}' not found — pick another or Rescan profiles.")

        up = Gtk.Button(label="▲")
        down = Gtk.Button(label="▼")
        remove = Gtk.Button(label="✕")
        for b in (up, down, remove):
            b.set_size_request(28, -1)

        rec = {"box": row, "check": check, "entry": entry, "drop": drop,
               "warn": warn, "items": items}
        up.connect("clicked", lambda _b, r=rec: self.move_row(r, -1))
        down.connect("clicked", lambda _b, r=rec: self.move_row(r, +1))
        remove.connect("clicked", lambda _b, r=rec: self.remove_row(r))

        for w in (check, entry, drop, warn, up, down, remove):
            row.append(w)
        self.list_box.append(row)
        self.rows.append(rec)

    def move_row(self, rec, delta):
        i = self.rows.index(rec)
        j = i + delta
        if j < 0 or j >= len(self.rows):
            return
        self.rows[i], self.rows[j] = self.rows[j], self.rows[i]
        prev = None
        for r in self.rows:
            self.list_box.reorder_child_after(r["box"], prev)
            prev = r["box"]

    def remove_row(self, rec):
        self.list_box.remove(rec["box"])
        self.rows.remove(rec)

    def _refresh_drop(self, drop, items, cur, warn=None):
        new_items, missing = self.model_items(cur)
        drop.set_model(Gtk.StringList.new(new_items))
        if cur in new_items:
            drop.set_selected(new_items.index(cur))
        if warn is not None:
            warn.set_visible(missing)
            if missing:
                warn.set_tooltip_text(f"Profile '{cur}' not found — pick another or Rescan profiles.")
        return new_items

    def on_rescan(self, _btn):
        existing = read_lines(BROWSERS)
        seen = {normcmd(l.split("|||", 1)[1]) for l in existing if "|||" in l}
        lines = list(existing)
        added = 0
        for label, cmd in discover_browsers():
            if normcmd(cmd) in seen:
                continue
            lines.append(f"{label}|||{cmd}")
            seen.add(normcmd(cmd))
            added += 1
        with open(BROWSERS, "w") as f:
            f.write("# Browsers + profiles offered by the picker.\n"
                    "# Format: Label|||command   (command may contain quotes; URL appended)\n")
            f.write("\n".join(lines) + "\n")
        self.labels = load_labels()
        for rec in self.rows:
            idx = rec["drop"].get_selected()
            cur = rec["items"][idx] if 0 <= idx < len(rec["items"]) else None
            if cur == NONE_FOUND:  # placeholder, not a real (missing) profile
                cur = None
            rec["items"] = self._refresh_drop(rec["drop"], rec["items"], cur, rec["warn"])
        # Default dropdown
        didx = self.default_drop.get_selected()
        dcur = self.default_items[didx] if 0 <= didx < len(self.default_items) else ASK
        ditems, dmissing = self.model_items(None if dcur in (ASK, NONE_FOUND) else dcur)
        self.default_items = [ASK] + ditems
        self.default_drop.set_model(Gtk.StringList.new(self.default_items))
        self.default_drop.set_selected(self.default_items.index(dcur) if dcur in self.default_items else 0)
        self.default_warn.set_visible(dmissing)
        if dmissing:
            self.default_warn.set_tooltip_text(f"Profile '{dcur}' not found.")
        self.status.set_text(f"Rescan: +{added} new profile(s) ({len(self.labels)} total).")

    def on_save(self, _btn):
        os.makedirs(CONF, exist_ok=True)
        lines = [
            "# Smart-default rules — managed by the \"Browser Picker Rules\" app (browser-picker-rules).",
            "# Format: enabled|||pattern|||label   (enabled 1/0; plain/glob/regex: pattern)",
        ]
        n = 0
        missing = 0
        for r in self.rows:
            pat = r["entry"].get_text().strip()
            if not pat:
                continue
            idx = r["drop"].get_selected()
            items = r["items"]
            if not items or idx >= len(items) or items[idx] == NONE_FOUND:
                continue
            lbl = items[idx]
            if lbl not in self.labels:
                missing += 1
            en = "1" if r["check"].get_active() else "0"
            lines.append(f"{en}|||{pat}|||{lbl}")
            n += 1
        # Catch-all default for unmatched links.
        didx = self.default_drop.get_selected()
        if 0 < didx < len(self.default_items) and self.default_items[didx] != NONE_FOUND:
            lines.append(f"1|||*|||{self.default_items[didx]}")
        with open(RULES, "w") as f:
            f.write("\n".join(lines) + "\n")

        if self.url:
            if not self.no_open:
                subprocess.Popen(["setsid", "-f", "browser-picker", self.url],
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            self.quit()
        else:
            msg = f"Saved {n} rule(s)."
            if missing:
                msg += f"  ⚠ {missing} reference a missing profile."
            self.status.set_text(msg)


if __name__ == "__main__":
    _url, _pattern, _label, _no_open = parse_args(sys.argv[1:])
    RulesApp(_url, _pattern, _label, _no_open).run(None)
